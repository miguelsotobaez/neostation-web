---
import PageLayout from "@/layouts/Base.astro";
import { Icon } from "astro-icon/components";

const meta = {
  description:
    "Your payment was cancelled. No charges have been made to your account.",
  title: "Payment Cancelled - NeoStation",
};
---

<!-- Need to move payments to other domain because its for neosync -->
<PageLayout meta={meta}>
  <div class="max-w-5xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <div
        class="w-20 h-20 mx-auto mb-6 bg-red-600 rounded-full flex items-center justify-center"
      >
        <Icon name="heroicons:x-circle" class="w-10 h-10 text-white" />
      </div>

      <h1 class="title mb-6 text-red-500">Payment Cancelled</h1>

      <p
        id="cancel-message"
        class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto"
      >
        Your payment has been cancelled. No charges have been made to your
        account.
      </p>
    </div>

    <script>
      // Get query parameters from URL
      const urlParams = new URLSearchParams(window.location.search);
      const username = urlParams.get("username") || "User";
      const plan = urlParams.get("plan") || "your plan";
      const period = urlParams.get("period") || "monthly";

      // Update the message with the parameters
      const messageElement = document.getElementById("cancel-message");
      if (messageElement) {
        messageElement.textContent = `${username}, your payment for the ${plan} plan (${period}) has been cancelled. No charges have been made to your account.`;
      }
    </script>

    <!-- Cancellation Content -->
    <div
      class="bg-slate-800/30 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-8 md:p-12 shadow-xl"
    >
      <div class="text-center space-y-6">
        <div
          class="bg-white/50 dark:bg-slate-800/50 rounded-xl p-6 border border-orange-200/50 dark:border-orange-800/50"
        >
          <h2
            class="text-2xl font-bold text-orange-700 dark:text-orange-300 mb-4"
          >
            No Worries!
          </h2>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Your payment was cancelled and no charges have been processed. You
            can try again whenever you're ready.
          </p>
        </div>

        <div
          class="bg-blue-50/50 dark:bg-blue-900/20 rounded-lg p-4 border border-blue-200/50 dark:border-blue-800/50"
        >
          <p class="text-sm text-blue-700 dark:text-blue-300">
            You can return to the NeoStation app to try again later.
          </p>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
