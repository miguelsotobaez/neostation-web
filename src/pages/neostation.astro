---
import PageLayout from "@/layouts/Base.astro";
import { Icon } from "astro-icon/components";
import SocialList from "@/components/SocialList.astro";

const meta = {
  description:
    "NeoStation - Modern multi-platform retro gaming frontend with RetroAchievements, ScreenScraper, and cross-platform compatibility.",
  title: "What is NeoStation? - NeoStation",
  ogImage: "/screenshots/neostation-01.webp",
};

const pillars = [
  {
    title: "Multi-Platform",
    icon: "mdi:devices",
    color: "text-[#2fa593]",
    description:
      "One frontend, every device. Windows, Android, Linux, and macOS share the same interface, library, and experience. Start on your PC, pick up on your handheld.",
  },
  {
    title: "RetroAchievements",
    icon: "mdi:trophy",
    color: "text-amber-400",
    description:
      "Built-in RetroAchievements integration. Track your unlocked achievements, view progress, and compete on leaderboards directly from the frontend, no extra setup.",
  },
  {
    title: "ScreenScraper",
    icon: "mdi:image-search",
    color: "text-blue-400",
    description:
      "Automatic metadata and artwork scraping via ScreenScraper. Box art, descriptions, release dates, and ratings, your library looks exactly how it should.",
  },
];

const platforms = [
  { name: "Windows", icon: "simple-icons:windows", color: "text-blue-400", note: "10 / 11 (64-bit)" },
  { name: "Android", icon: "simple-icons:android", color: "text-green-400", note: "7.0+ (API 24+)" },
  { name: "Linux", icon: "simple-icons:linux", color: "text-orange-400", note: "AppImage (x64 / ARM64)" },
  { name: "macOS", icon: "simple-icons:apple", color: "text-indigo-400", note: "Intel & Apple Silicon" },
];
---

<PageLayout meta={meta}>
  <div class="relative py-12 md:py-20 overflow-hidden">
    <!-- Background Accents -->
    <div
      class="absolute top-0 right-0 -mt-20 -mr-20 w-96 h-96 bg-[#2fa593]/5 blur-[120px] rounded-full pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 -mb-20 -ml-20 w-80 h-80 bg-blue-500/5 blur-[100px] rounded-full pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4">
      <!-- Hero -->
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight">
          What is <span class="text-[#2fa593]">NeoStation?</span>
        </h1>
        <div class="max-w-3xl mx-auto">
          <p class="text-lg md:text-xl text-gray-400 leading-relaxed">
            A modern, open source retro gaming frontend built for
            <span class="text-white font-semibold italic">every platform</span>.
            Beautiful UI, automatic metadata, achievement tracking, everything
            your collection deserves.
          </p>
        </div>
      </div>

      <!-- Screenshot Slider -->
      <div class="relative max-w-5xl mx-auto mb-24">
        <div
          class="absolute inset-0 bg-[#2fa593]/10 blur-[80px] rounded-full pointer-events-none"
        >
        </div>
        <div
          class="relative w-full aspect-video rounded-3xl overflow-hidden shadow-2xl border border-white/10 z-10 bg-[#26292e]"
          id="hero-slider"
        >
          {
            [1, 2, 3, 4].map((num, index) => (
              <img
                src={`/screenshots/neostation-0${num}.webp`}
                alt={`NeoStation Interface ${num}`}
                class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${index === 0 ? "opacity-100" : "opacity-0"}`}
                data-index={index}
              />
            ))
          }
          <div
            class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-[#1d2024]/80 to-transparent"
          >
          </div>
        </div>
      </div>

      <!-- Core Pillars -->
      <div class="grid md:grid-cols-3 gap-8 mb-24">
        {
          pillars.map((pillar) => (
            <div class="group p-8 rounded-3xl bg-[#26292e] border border-white/5 hover:border-[#2fa593]/50 transition-all duration-300 hover:shadow-xl hover:shadow-[#2fa593]/10 hover:-translate-y-1">
              <div class="w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center mb-6 group-hover:bg-[#2fa593]/10 transition-colors">
                <Icon name={pillar.icon} class={`w-6 h-6 ${pillar.color}`} />
              </div>
              <h3 class="text-xl font-bold text-white mb-4 group-hover:text-[#2fa593] transition-colors">
                {pillar.title}
              </h3>
              <p class="text-gray-400 leading-relaxed text-sm">
                {pillar.description}
              </p>
            </div>
          ))
        }
      </div>

      <!-- Multi-Platform Section -->
      <div class="grid lg:grid-cols-2 gap-12 mb-24 items-center">
        <div class="space-y-8">
          <div>
            <h2 class="text-3xl font-bold text-white mb-6 border-l-4 border-[#2fa593] pl-6 italic">
              One App. Every Device.
            </h2>
            <p class="text-gray-400 leading-relaxed mb-6">
              NeoStation runs natively on Windows, Android, Linux, and macOS
              with a landscape-optimized interface designed for both desktop
              monitors and handheld screens. Your library, settings, and
              experience stay consistent across every device you own.
            </p>
            <p class="text-gray-400 leading-relaxed">
              Android TV and Google TV are also supported, including a built-in
              file explorer for devices that lack a native file picker.
            </p>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="p-6 rounded-2xl bg-[#26292e] border border-white/5">
              <div class="text-3xl font-bold text-[#2fa593] mb-1">100+</div>
              <div class="text-xs text-gray-500 uppercase font-bold tracking-wider">
                Systems Supported
              </div>
            </div>
            <div class="p-6 rounded-2xl bg-[#26292e] border border-white/5">
              <div class="text-3xl font-bold text-blue-400 mb-1">4</div>
              <div class="text-xs text-gray-500 uppercase font-bold tracking-wider">
                Native Platforms
              </div>
            </div>
          </div>
        </div>

        <!-- Platform Cards -->
        <div class="grid grid-cols-2 gap-4">
          {
            platforms.map((p) => (
              <div class="p-6 rounded-2xl bg-[#26292e] border border-white/5 hover:border-white/10 transition-all flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center shrink-0">
                  <Icon name={p.icon} class={`w-6 h-6 ${p.color}`} />
                </div>
                <div>
                  <div class="text-white font-bold text-sm">{p.name}</div>
                  <div class="text-gray-500 text-xs">{p.note}</div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Integrations Section -->
      <div class="mb-24">
        <div class="flex items-center gap-4 mb-12">
          <h2 class="text-3xl font-bold text-white pl-6 border-l-4 border-amber-500">
            Integrations
          </h2>
          <div class="flex-grow h-[1px] bg-white/5"></div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <!-- RetroAchievements -->
          <div class="bg-gradient-to-br from-[#26292e] to-[#1d2024] p-8 rounded-3xl border border-white/5 shadow-2xl relative overflow-hidden group hover:border-amber-500/30 transition-all">
            <div class="absolute top-0 right-0 -mt-8 -mr-8 w-32 h-32 bg-amber-500/5 blur-[40px] rounded-full group-hover:bg-amber-500/10 transition-colors"></div>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-2xl bg-amber-500/10 flex items-center justify-center shrink-0">
                <Icon name="mdi:trophy" class="w-7 h-7 text-amber-400" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white">RetroAchievements</h3>
                <a href="https://retroachievements.org" target="_blank" class="text-xs text-gray-500 hover:text-amber-400 transition-colors">retroachievements.org ↗</a>
              </div>
            </div>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <Icon name="mdi:check-circle" class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" />
                <span class="text-sm text-gray-400">Login with your RetroAchievements account directly in the app.</span>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="mdi:check-circle" class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" />
                <span class="text-sm text-gray-400">View per-game achievement progress and unlocks at a glance.</span>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="mdi:check-circle" class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" />
                <span class="text-sm text-gray-400">Systems incompatible with RA are automatically hidden from RA UI elements.</span>
              </li>
            </ul>
          </div>

          <!-- ScreenScraper -->
          <div class="bg-gradient-to-br from-[#26292e] to-[#1d2024] p-8 rounded-3xl border border-white/5 shadow-2xl relative overflow-hidden group hover:border-blue-500/30 transition-all">
            <div class="absolute top-0 right-0 -mt-8 -mr-8 w-32 h-32 bg-blue-500/5 blur-[40px] rounded-full group-hover:bg-blue-500/10 transition-colors"></div>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-2xl bg-blue-500/10 flex items-center justify-center shrink-0">
                <Icon name="mdi:image-search" class="w-7 h-7 text-blue-400" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white">ScreenScraper</h3>
                <a href="https://www.screenscraper.fr" target="_blank" class="text-xs text-gray-500 hover:text-blue-400 transition-colors">screenscraper.fr ↗</a>
              </div>
            </div>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <Icon name="mdi:check-circle" class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" />
                <span class="text-sm text-gray-400">Scrape box art, screenshots, descriptions, and release dates automatically.</span>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="mdi:check-circle" class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" />
                <span class="text-sm text-gray-400">Batch scrape entire libraries or scrape individual games on demand.</span>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="mdi:check-circle" class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" />
                <span class="text-sm text-gray-400">Real game names from ScreenScraper can replace raw ROM filenames in the UI.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Gallery -->
      <div class="mb-24">
        <div class="flex items-center justify-between mb-12">
          <h2 class="text-3xl font-bold text-white pl-6 border-l-4 border-[#2fa593]">
            Visual Journey
          </h2>
          <div class="hidden md:block h-[1px] flex-grow mx-8 bg-white/5"></div>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
          {
            [1, 2, 3, 4, 5, 6, 7, 8].map((num) => (
              <div
                class="group relative aspect-video overflow-hidden rounded-2xl bg-[#26292e] border border-white/5 hover:border-[#2fa593]/50 transition-all duration-300 cursor-pointer modal-trigger shadow-lg"
                data-image={`/screenshots/neostation-0${num}.webp`}
              >
                <img
                  src={`/screenshots/neostation-0${num}.webp`}
                  alt={`NeoStation Screenshot ${num}`}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-70 group-hover:opacity-100"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                  <span class="text-white text-xs font-bold uppercase tracking-widest">
                    Enlarge
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- CTA -->
      <div class="relative group">
        <div
          class="absolute inset-0 bg-gradient-to-r from-[#2fa593] to-blue-600 rounded-3xl blur-xl opacity-10 group-hover:opacity-20 transition-opacity"
        >
        </div>
        <div
          class="relative bg-[#26292e] rounded-3xl border border-white/10 p-12 text-center overflow-hidden"
        >
          <div class="relative z-10">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
              Ready to upgrade your collection?
            </h2>
            <p class="text-gray-400 mb-10 max-w-xl mx-auto">
              Download NeoStation and join the community building the future of retro gaming.
            </p>
            <div class="flex flex-wrap justify-center gap-4">
              <a
                href="/downloads"
                class="px-8 py-4 bg-[#2fa593] hover:bg-[#268d7e] text-white font-bold rounded-xl transition-all transform hover:scale-105 active:scale-95 shadow-lg shadow-[#2fa593]/20"
              >
                Download Now
              </a>
              <a
                href="https://discord.gg/xE2kgKsRVq"
                class="px-8 py-4 bg-white/5 hover:bg-white/10 text-white font-bold rounded-xl transition-all border border-white/10"
              >
                Join the Discord
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 pb-16">
    <SocialList />
  </div>
</PageLayout>

<!-- Image Modal -->
<div
  id="imageModal"
  class="fixed inset-0 bg-black bg-opacity-75 hidden z-50 flex items-center justify-center p-4"
>
  <div class="relative max-w-4xl max-h-full">
    <img
      id="modalImage"
      src=""
      alt="NeoStation Screenshot"
      class="rounded-xl shadow-2xl max-w-full max-h-full object-contain"
    />
    <button
      id="closeModal"
      class="absolute top-4 right-4 text-white text-3xl font-bold hover:text-gray-300 transition-colors bg-black/20 hover:bg-black/40 w-10 h-10 flex items-center justify-center rounded-full"
    >
      &times;
    </button>
  </div>
</div>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll("#hero-slider img");
  const totalSlides = slides.length;

  if (totalSlides > 0) {
    setInterval(() => {
      slides[currentSlide]!.classList.remove("opacity-100");
      slides[currentSlide]!.classList.add("opacity-0");
      currentSlide = (currentSlide + 1) % totalSlides;
      slides[currentSlide]!.classList.remove("opacity-0");
      slides[currentSlide]!.classList.add("opacity-100");
    }, 5000);
  }

  const modal = document.getElementById("imageModal");
  const modalImage = document.getElementById("modalImage") as HTMLImageElement;
  const closeBtn = document.getElementById("closeModal");
  const triggers = document.querySelectorAll(".modal-trigger");

  function openModal(src: string) {
    if (modal && modalImage) {
      modalImage.src = src;
      modal.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }
  }

  function closeModal() {
    if (modal) {
      modal.classList.add("hidden");
      document.body.style.overflow = "auto";
    }
  }

  triggers.forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const src = trigger.getAttribute("data-image");
      if (src) openModal(src);
    });
  });

  closeBtn?.addEventListener("click", closeModal);

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>
